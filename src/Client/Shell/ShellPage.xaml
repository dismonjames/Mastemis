<Page x:Class="Mastemis.Client.Shell.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource MastemisCanvasBrush}">
        <!-- Onboarding is intentionally independent from authenticated navigation. -->
        <Grid x:Name="OnboardingRoot" RowDefinitions="Auto,*">
            <ContentControl x:Name="OnboardingReviewFixture" Visibility="Collapsed" HorizontalContentAlignment="Stretch" />
            <Frame x:Name="OnboardingFrame" />
        </Grid>

        <NavigationView x:Name="Navigation"
                        Visibility="Collapsed"
                        PaneDisplayMode="Auto"
                        CompactPaneLength="52"
                        OpenPaneLength="224"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        AlwaysShowHeader="False"
                        ItemInvoked="Navigation_ItemInvoked"
                        Background="{ThemeResource MastemisCanvasBrush}"
                        AutomationProperties.Name="Mastemis application navigation">
            <NavigationView.PaneHeader>
                <StackPanel Margin="8,14,8,12" Spacing="2">
                    <TextBlock Text="Mastemis" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ServerName}" Style="{StaticResource MastemisCaptionTextStyle}" />
                </StackPanel>
            </NavigationView.PaneHeader>
            <NavigationView.PaneFooter>
                <Border Margin="4,8" Padding="10" Background="{ThemeResource MastemisSubtleBrush}" CornerRadius="6" AutomationProperties.Name="Signed-in account and connection status">
                    <StackPanel Spacing="7">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="{ThemeResource MastemisSuccessBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RealtimeState}" Style="{StaticResource MastemisCaptionTextStyle}" />
                        </StackPanel>
                        <Button Content="Sign out" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch" AutomationProperties.HelpText="End the current Mastemis session." />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>
            <Grid RowDefinitions="Auto,*">
                <ContentControl x:Name="AuthenticatedReviewFixture" Visibility="Collapsed" HorizontalContentAlignment="Stretch" />
                <Frame x:Name="ContentFrame" Grid.Row="1" />
            </Grid>
        </NavigationView>
        <Rectangle x:Name="ReviewCaptureMarker" Width="8" Height="8" Fill="#FFFF00FF" Margin="4"
                   HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False"
                   Visibility="Collapsed" Canvas.ZIndex="1000" AutomationProperties.AccessibilityView="Raw" />
    </Grid>
</Page>
