<UserControl x:Class="Mastemis.Client.VisualReview.VisualFixturePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch">
    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="ReviewWidthStates">
            <VisualState x:Name="CompactReview">
                <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0" /></VisualState.StateTriggers>
                <VisualState.Setters><Setter Target="FixtureSections.Visibility" Value="Collapsed" /></VisualState.Setters>
            </VisualState>
            <VisualState x:Name="WideReview">
                <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1150" /></VisualState.StateTriggers>
                <VisualState.Setters><Setter Target="FixtureSections.Visibility" Value="Visible" /></VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <Border Background="{ThemeResource MastemisSubtleBrush}"
            BorderBrush="{ThemeResource MastemisBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,10"
            AutomationProperties.LiveSetting="Polite"
            AutomationProperties.Name="Deterministic visual review fixture">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
            <StackPanel>
                <TextBlock Text="VISUAL REVIEW" Style="{StaticResource MastemisEyebrowTextStyle}" />
                <TextBlock Text="{Binding Scenario}" FontWeight="SemiBold" />
            </StackPanel>
            <ItemsControl x:Name="FixtureSections" Grid.Column="1" ItemsSource="{Binding Sections}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="28" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel MaxWidth="330">
                            <TextBlock Text="{Binding Heading}" Style="{StaticResource MastemisCaptionTextStyle}" />
                            <ItemsControl ItemsSource="{Binding Values}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Value}" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock x:Name="ContextText" FontWeight="SemiBold" />
                <TextBlock Text="Fixture data · no network" Style="{StaticResource MastemisCaptionTextStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
