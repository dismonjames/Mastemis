<Page
    x:Class="Mastemis.Client.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Padding="24,16" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE80F;" FontSize="24"/>
                <TextBlock Text="Mastemis" FontSize="24" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1">
            <Grid MaxWidth="560" Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Connect to a Mastemis server" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Choose Host Mode for server operators or Connect Mode for an existing deployment." TextWrapping="Wrap" Opacity="0.72"/>
                    <ComboBox Header="Mode" SelectedIndex="1" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode, Mode=TwoWay}"/>
                    <TextBox Header="Server URL" Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="https://mastemis.example.edu"/>
                    <Button Content="Test connection" Command="{Binding TestConnectionCommand}" HorizontalAlignment="Stretch"/>
                    <ProgressRing IsActive="{Binding IsBusy}" HorizontalAlignment="Center"/>
                    <InfoBar IsOpen="{Binding HasStatus}" Severity="Informational" Title="{Binding StatusTitle}" Message="{Binding StatusMessage}" IsClosable="False"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
