<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="MastemisCanvasBrush" Color="#F6F8FB" />
            <SolidColorBrush x:Key="MastemisSurfaceBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="MastemisSubtleBrush" Color="#EEF2F7" />
            <SolidColorBrush x:Key="MastemisBorderBrush" Color="#D7DEE8" />
            <SolidColorBrush x:Key="MastemisMutedTextBrush" Color="#526071" />
            <SolidColorBrush x:Key="MastemisAccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="MastemisSuccessBrush" Color="#15803D" />
            <SolidColorBrush x:Key="MastemisWarningBrush" Color="#B45309" />
            <SolidColorBrush x:Key="MastemisDangerBrush" Color="#B91C1C" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="MastemisCanvasBrush" Color="#0B1220" />
            <SolidColorBrush x:Key="MastemisSurfaceBrush" Color="#111B2E" />
            <SolidColorBrush x:Key="MastemisSubtleBrush" Color="#1A263B" />
            <SolidColorBrush x:Key="MastemisBorderBrush" Color="#334155" />
            <SolidColorBrush x:Key="MastemisMutedTextBrush" Color="#A7B3C5" />
            <SolidColorBrush x:Key="MastemisAccentBrush" Color="#60A5FA" />
            <SolidColorBrush x:Key="MastemisSuccessBrush" Color="#4ADE80" />
            <SolidColorBrush x:Key="MastemisWarningBrush" Color="#FBBF24" />
            <SolidColorBrush x:Key="MastemisDangerBrush" Color="#F87171" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    <x:Double x:Key="MastemisRadiusSmall">4</x:Double>
    <x:Double x:Key="MastemisRadiusMedium">8</x:Double>
    <x:Double x:Key="MastemisRadiusLarge">12</x:Double>
</ResourceDictionary>
