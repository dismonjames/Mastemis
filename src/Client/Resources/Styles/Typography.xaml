<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <x:Double x:Key="MastemisPageTitleFontSize">28</x:Double>
    <x:Double x:Key="MastemisSectionTitleFontSize">18</x:Double>
    <x:Double x:Key="MastemisCaptionFontSize">12</x:Double>
    <x:Double x:Key="MastemisEditorFontSize">14</x:Double>
    <Style x:Key="MastemisPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{ThemeResource MastemisPageTitleFontSize}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="TextWrapping" Value="Wrap"/><Setter Property="Foreground" Value="{ThemeResource MastemisTextBrush}"/>
    </Style>
    <Style x:Key="MastemisSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{ThemeResource MastemisSectionTitleFontSize}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="MastemisMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource MastemisMutedTextBrush}"/><Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="MastemisCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MastemisMutedTextStyle}">
        <Setter Property="FontSize" Value="{ThemeResource MastemisCaptionFontSize}"/>
    </Style>
    <Style x:Key="MastemisEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{ThemeResource MastemisCaptionFontSize}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="{ThemeResource MastemisAccentBrush}"/><Setter Property="CharacterSpacing" Value="70"/>
    </Style>
    <Style x:Key="MastemisCodeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas,monospace"/><Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
</ResourceDictionary>
