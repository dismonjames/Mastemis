<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MastemisFormComboBoxStyle" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="MastemisFormNumberBoxStyle" TargetType="NumberBox">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="MastemisDestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource MastemisSecondaryButtonStyle}">
        <Setter Property="Foreground" Value="{ThemeResource MastemisDangerBrush}"/>
        <Setter Property="AutomationProperties.HelpText" Value="This action changes or removes durable state."/>
    </Style>
</ResourceDictionary>
