<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MastemisInlineStatusStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="{ThemeResource MastemisSubtleBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource MastemisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style x:Key="MastemisPermissionNoticeStyle" TargetType="Border">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="{ThemeResource MastemisWarningSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource MastemisWarningBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
