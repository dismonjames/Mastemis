<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MastemisCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource MastemisSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource MastemisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
    </Style>
    <Style x:Key="MastemisPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinHeight" Value="42"/><Setter Property="Padding" Value="18,8"/><Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="MastemisFormTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="42"/><Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style x:Key="MastemisStatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource MastemisSubtleBrush}"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="10,4"/>
    </Style>
    <Style x:Key="MastemisModeChoiceStyle" TargetType="RadioButton">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="MinHeight" Value="108"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0"/>
    </Style>
    <Style x:Key="MastemisSecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="42"/><Setter Property="Padding" Value="16,8"/><Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style x:Key="MastemisEditorTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{ThemeResource MastemisEditorBrush}"/><Setter Property="BorderBrush" Value="{ThemeResource MastemisBorderBrush}"/><Setter Property="FontFamily" Value="Cascadia Mono,Consolas,monospace"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="14"/>
    </Style>
</ResourceDictionary>
