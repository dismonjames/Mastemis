<Page x:Class="Mastemis.Client.Pages.Examinations.ExaminationsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer><StackPanel Margin="28" Spacing="18" MaxWidth="1000"><TextBlock Text="Examinations" Style="{StaticResource MastemisPageTitleStyle}"/><TextBlock Text="Create an examination or inspect an authorized examination by identifier." Style="{StaticResource MastemisMutedTextStyle}"/>
  <Border Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="12"><TextBlock Text="Create examination" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Header="Title" Text="{Binding Title, Mode=TwoWay}"/><Button Content="Create" Command="{Binding CreateCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel></Border>
  <Border Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="12"><TextBlock Text="Examination details" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Header="Examination ID" Text="{Binding ExamId, Mode=TwoWay}"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Refresh" Command="{Binding RefreshCommand}"/><Button Content="Open" Command="{Binding OpenCommand}"/><Button Content="Close" Command="{Binding CloseCommand}"/></StackPanel><TextBlock Text="{Binding Examination.Title}" FontWeight="SemiBold"/><TextBlock Text="{Binding Examination.State}"/></StackPanel></Border>
  <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Request failed" Message="{Binding Error}" IsClosable="False"/>
 </StackPanel></ScrollViewer>
</Page>
