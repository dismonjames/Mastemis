<Page x:Class="Mastemis.Client.Pages.Dashboard.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="20" MaxWidth="1320" HorizontalAlignment="Stretch">
            <controls:PageHeader Eyebrow="{Binding DashboardContext}" Title="{Binding Greeting}" Subtitle="{Binding RoleSummary}">
                <controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}"/></controls:PageHeader.Commands>
            </controls:PageHeader>

            <InfoBar IsOpen="{Binding HasError}" Severity="Warning" Title="Server status could not be refreshed" Message="{Binding Error}" IsClosable="False"/>
            <ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <controls:MetricTile Label="{Binding PrimaryMetricLabel}" Value="—" Detail="No aggregate endpoint" Glyph="&#xE787;"/>
                <controls:MetricTile Grid.Column="1" Label="{Binding SecondaryMetricLabel}" Value="—" Detail="No aggregate endpoint" Glyph="&#xE9D9;"/>
                <controls:MetricTile Grid.Column="2" Label="Server readiness" Value="{Binding HealthState}" Detail="PostgreSQL · queues · storage" Glyph="&#xE930;"/>
                <controls:MetricTile Grid.Column="3" Label="Realtime activity" Value="{Binding RecentActivity.Count}" Detail="This client session" Glyph="&#xE753;"/>
            </Grid>

            <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Operational focus" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Title="No aggregate operational data" Message="This server version does not expose a dashboard aggregate. Open a scoped examination, room, or problem to load authoritative records." Glyph="&#xE80F;"/></StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Recent realtime activity" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Visibility="{Binding HasRecentActivity, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No events yet" Message="Authorized realtime events will appear here after group subscription." Glyph="&#xE753;"/><ListView ItemsSource="{Binding RecentActivity}" MinHeight="160"><ListView.ItemTemplate><DataTemplate><Grid Padding="8,5"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Type}"/><TextBlock Grid.Column="1" Text="{Binding OccurredAtUtc}" Style="{StaticResource MastemisCaptionTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Metrics remain unavailable until the backend exposes authorized aggregate queries; Mastemis never fabricates operational counts." Style="{StaticResource MastemisCaptionTextStyle}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
