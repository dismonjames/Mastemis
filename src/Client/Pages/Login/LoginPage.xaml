<Page x:Class="Mastemis.Client.Pages.Login.LoginPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource MastemisCanvasBrush}"><Border Style="{StaticResource MastemisCardStyle}" Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="16"><TextBlock Text="Sign in" Style="{StaticResource MastemisPageTitleStyle}"/>
            <TextBox Header="Username" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <PasswordBox Header="Password" PasswordChanged="PasswordBox_PasswordChanged"/>
            <CheckBox Content="Keep this session signed in" IsChecked="{Binding RememberMe, Mode=TwoWay}"/>
            <Button Content="Sign in" Command="{Binding LoginCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
            <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Sign-in failed" Message="{Binding ErrorMessage}" IsClosable="False"/>
        </StackPanel>
    </Border></Grid>
</Page>
