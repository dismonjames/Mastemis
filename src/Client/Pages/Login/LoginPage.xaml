<Page x:Class="Mastemis.Client.Pages.Login.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource MastemisCanvasBrush}">
        <Grid.RowDefinitions><RowDefinition Height="64"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="{ThemeResource MastemisNavigationBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1">
            <Grid MaxWidth="1180" Margin="24,0" HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center"><Border Width="32" Height="32" CornerRadius="7" Background="{ThemeResource MastemisAccentBrush}"><TextBlock Text="M" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Spacing="0"><TextBlock Text="Mastemis" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Secure examination environment" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></StackPanel>
                <Button Grid.Column="1" Command="{Binding ChangeServerCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}" AutomationProperties.Name="Change Mastemis server"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE774;" FontSize="15"/><TextBlock Text="Change server"/></StackPanel></Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <Grid MaxWidth="860" Margin="28,52,28,44" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions><ColumnDefinition Width="5*"/><ColumnDefinition Width="6*"/></Grid.ColumnDefinitions>
                <StackPanel Margin="0,10,44,0" Spacing="18">
                    <StackPanel Spacing="7"><TextBlock Text="Welcome back" Style="{StaticResource MastemisPageTitleStyle}"/><TextBlock Text="Sign in with the account issued by your Mastemis administrator." FontSize="15" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel>
                    <Border Padding="16" Background="{ThemeResource MastemisSubtleBrush}" CornerRadius="8"><StackPanel Spacing="7"><TextBlock Text="CONNECTED SERVER" Style="{StaticResource MastemisEyebrowTextStyle}"/><TextBlock Text="{Binding ServerName}" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{Binding ServerAddress}" Style="{StaticResource MastemisCaptionTextStyle}"/><Border Style="{StaticResource MastemisStatusPillStyle}" HorizontalAlignment="Left"><TextBlock Text="{Binding ModeLabel}" FontSize="12"/></Border></StackPanel></Border>
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE72E;" Foreground="{ThemeResource MastemisSuccessBrush}" FontSize="15"/><TextBlock Text="Connection verified" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="28">
                    <StackPanel Spacing="17">
                        <StackPanel Spacing="5"><TextBlock Text="Sign in" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="Your session is managed securely by the selected server." Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel>
                        <TextBox Header="Username" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Username" Style="{StaticResource MastemisFormTextBoxStyle}"/>
                        <PasswordBox Header="Password" PasswordChanged="PasswordBox_PasswordChanged" PasswordRevealMode="Peek" AutomationProperties.Name="Password" MinHeight="42"/>
                        <CheckBox Content="Keep this session signed in" IsChecked="{Binding RememberMe, Mode=TwoWay}" AutomationProperties.HelpText="The server controls session duration. The password is never saved."/>
                        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Unable to sign in" Message="{Binding ErrorMessage}" IsClosable="False"/>
                        <Button Content="Sign in" Command="{Binding LoginCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Stretch" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
                        <ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="Mastemis does not send credentials to any third party." TextAlignment="Center" Style="{StaticResource MastemisCaptionTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
