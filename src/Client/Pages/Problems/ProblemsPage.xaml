<Page x:Class="Mastemis.Client.Pages.Problems.ProblemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Mastemis.Client.Controls">
    <Grid Padding="{StaticResource MastemisPageMargin}" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <controls:PageHeader Eyebrow="AUTHORING" Title="Problem library" Subtitle="Search authorized drafts and open them in Problem Studio.">
            <controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshCommand}"/></controls:PageHeader.Commands>
        </controls:PageHeader>
        <Grid Grid.Row="1" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="320"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox PlaceholderText="Search by title" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Search problems"/>
            <TextBox Grid.Column="1" PlaceholderText="New problem title" Text="{Binding NewTitle, Mode=TwoWay}" AutomationProperties.Name="New problem title"/>
            <Button Grid.Column="2" Content="Create draft" Command="{Binding CreateCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/>
        </Grid>
        <Border Grid.Row="2" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Padding="16,12" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Title" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="Locale" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="Checker" FontWeight="SemiBold"/><TextBlock Grid.Column="3" Text="Revision" FontWeight="SemiBold"/>
                </Grid>
                <ListView Grid.Row="1" ItemsSource="{Binding VisibleProblems}" AutomationProperties.Name="Authorized problem drafts">
                    <ListView.ItemTemplate><DataTemplate><Grid Padding="8,7"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Title}"/><TextBlock Grid.Column="1" Text="{Binding DefaultLocale}"/><TextBlock Grid.Column="2" Text="{Binding Checker}"/><TextBlock Grid.Column="3" Text="{Binding Version}"/></Grid></DataTemplate></ListView.ItemTemplate>
                </ListView>
                <controls:EmptyState Grid.Row="1" Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" Title="No authorized drafts" Message="Create a draft or ask an owner to assign you to a problem." Glyph="&#xE8A5;"/>
            </Grid>
        </Border>
        <InfoBar Grid.Row="2" VerticalAlignment="Top" IsOpen="{Binding HasError}" Severity="Error" Title="Problem request failed" Message="{Binding Error}" IsClosable="False"/>
    </Grid>
</Page>
