<Page x:Class="Mastemis.Client.Pages.Evidence.EvidencePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Mastemis.Client.Controls">
    <Grid Padding="{StaticResource MastemisPageMargin}" RowSpacing="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <controls:PageHeader Eyebrow="AUTHORIZED REVIEW" Title="Evidence metadata" Subtitle="Review granted package metadata, immutable timelines, and access audits. Binary evidence is not implied."><controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshCommand}"/><Button Content="Inspect selected" Command="{Binding InspectCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></controls:PageHeader.Commands></controls:PageHeader>
        <Grid Grid.Row="1" ColumnSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Padding="16,12" Text="Granted packages" Style="{StaticResource MastemisSectionTitleStyle}"/><ListView Grid.Row="1" ItemsSource="{Binding Packages}" SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="8,6"><TextBlock Text="{Binding Id.Value}" FontWeight="SemiBold"/><TextBlock Text="{Binding CreatedAtUtc}" Style="{StaticResource MastemisCaptionTextStyle}"/><TextBlock Text="{Binding SessionId.Value}" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView><controls:EmptyState Grid.Row="1" Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" Title="No evidence grants" Message="Only explicitly granted package metadata appears here." Glyph="&#xE8D7;"/></Grid></Border>
            <TabView Grid.Column="1"><TabViewItem Header="Timeline"><ListView ItemsSource="{Binding Timeline}"><ListView.ItemTemplate><DataTemplate><Grid Padding="8,7"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Type}"/><TextBlock Grid.Column="1" Text="{Binding ContentType}"/><TextBlock Grid.Column="2" Text="{Binding ServerTimestampUtc}" Style="{StaticResource MastemisCaptionTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></TabViewItem><TabViewItem Header="Access audit"><ListView ItemsSource="{Binding Audit}"><ListView.ItemTemplate><DataTemplate><Grid Padding="8,7"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Action}" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding ResourceId}"/><TextBlock Grid.Column="2" Text="{Binding OccurredAtUtc}" Style="{StaticResource MastemisCaptionTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></TabViewItem></TabView>
        </Grid>
        <InfoBar Grid.Row="1" VerticalAlignment="Top" IsOpen="{Binding HasError}" Severity="Error" Title="Evidence request denied or unavailable" Message="{Binding Error}" IsClosable="False"/>
    </Grid>
</Page>
