<Page x:Class="Mastemis.Client.Pages.Connection.ConnectionPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource MastemisCanvasBrush}"><Grid MaxWidth="560" Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="16">
            <TextBlock Text="Connect to Mastemis" Style="{StaticResource MastemisPageTitleStyle}"/>
            <TextBlock Text="Host Mode administers a server. Connect Mode joins an existing deployment." Style="{StaticResource MastemisMutedTextStyle}"/>
            <ComboBox Header="Mode" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode, Mode=TwoWay}"/>
            <TextBox Header="Server URL" Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MastemisFormTextBoxStyle}"/>
            <Button Content="Test and continue" Command="{Binding TestConnectionCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
            <ProgressRing IsActive="{Binding IsBusy}" HorizontalAlignment="Center"/>
            <InfoBar IsOpen="{Binding HasStatus}" Title="{Binding StatusTitle}" Message="{Binding StatusMessage}" IsClosable="False"/>
        </StackPanel></Border>
    </Grid></Grid>
</Page>
