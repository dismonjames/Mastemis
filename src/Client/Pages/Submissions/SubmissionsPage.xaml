<Page x:Class="Mastemis.Client.Pages.Submissions.SubmissionsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="1180" HorizontalAlignment="Stretch">
        <controls:PageHeader Eyebrow="CANDIDATE" Title="Submissions" Subtitle="Authoritative compilation, execution, and judgement states for the loaded examination session.">
            <controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshSubmissionsCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}"/></controls:PageHeader.Commands>
        </controls:PageHeader>
        <StackPanel Orientation="Horizontal" Spacing="8"><TextBox Width="340" PlaceholderText="Session ID" Text="{Binding SessionId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Load history" Command="{Binding LoadCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel>
        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Submission history unavailable" Message="{Binding Error}" IsClosable="False"/>
        <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><StackPanel><Grid Padding="16,12" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Submission" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="Language" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold"/><TextBlock Grid.Column="3" Text="Final" FontWeight="SemiBold"/></Grid><controls:EmptyState Visibility="{Binding HasSubmissions, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No submissions" Message="Load a session or submit a saved source revision from the examination workspace." Glyph="&#xE8A5;"/><ListView ItemsSource="{Binding Submissions}"><ListView.ItemTemplate><DataTemplate><Grid Padding="12,9"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Id}" Style="{StaticResource MastemisCodeTextStyle}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="1" Text="{Binding Language}"/><TextBlock Grid.Column="2" Text="{Binding State}" FontWeight="SemiBold"/><CheckBox Grid.Column="3" IsChecked="{Binding IsFinal}" IsEnabled="False" AutomationProperties.Name="Final submission"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
        <InfoBar IsOpen="True" Severity="Informational" Title="Policy-safe diagnostics" Message="Compiler and runtime diagnostics appear only when the backend permits candidate access. Hidden expected outputs are never displayed." IsClosable="False"/>
    </StackPanel></ScrollViewer>
</Page>
