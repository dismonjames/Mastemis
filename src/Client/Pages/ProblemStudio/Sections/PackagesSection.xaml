<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.PackagesSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Padding="14" RowSpacing="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal" Spacing="8"><Border AllowDrop="True" DragOver="Package_DragOver" Drop="Package_Drop" Padding="12,7" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="6"><TextBlock Text="Drop one .mas package or choose a file"/></Border><Button Content="Choose .mas" Command="{Binding Packages.PickCommand}"/><Button Content="Validate" Command="{Binding Packages.ValidateCommand}"/><Button Content="Create new" Command="{Binding Packages.CreateNewCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/><Button Content="Replace draft" Command="{Binding Packages.ReplaceCommand}"/><Button Content="Create export" Command="{Binding Packages.ExportCommand}"/><TextBlock Text="{Binding Packages.PendingFile}" VerticalAlignment="Center"/></StackPanel><Grid Grid.Row="1" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Import history" Style="{StaticResource MastemisSectionTitleStyle}"/><ListView ItemsSource="{Binding Packages.Imports}" DisplayMemberPath="Mode"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Export history" Style="{StaticResource MastemisSectionTitleStyle}"/><ListView ItemsSource="{Binding Packages.Exports}" SelectedItem="{Binding Packages.SelectedExport, Mode=TwoWay}" DisplayMemberPath="Status"/></StackPanel></Grid><ListView Grid.Row="2" ItemsSource="{Binding Packages.Diagnostics}"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="7"><TextBlock Text="{Binding Code}" FontWeight="SemiBold"/><TextBlock Text="{Binding Message}" TextWrapping="Wrap"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView><StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"><Button Content="Refresh history" Command="{Binding Packages.RefreshCommand}"/><Button Content="Download selected" Command="{Binding Packages.DownloadCommand}"/><Button Content="Expire selected" Command="{Binding Packages.ExpireCommand}"/><ProgressBar Width="160" IsIndeterminate="{Binding Packages.IsTransferring}"/><TextBlock Text="{Binding Packages.TransferText}" VerticalAlignment="Center"/><TextBlock Text="{Binding Packages.Status}" VerticalAlignment="Center"/><TextBlock Text="{Binding Packages.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/></StackPanel></Grid>
</UserControl>
