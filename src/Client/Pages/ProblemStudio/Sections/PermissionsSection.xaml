<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.PermissionsSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Padding="14" RowSpacing="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/><ColumnDefinition Width="220"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="User identifier" Text="{Binding Permissions.UserId, Mode=TwoWay}"/><ComboBox Grid.Column="1" Header="Authoring role" SelectedValue="{Binding Permissions.Role, Mode=TwoWay}"><ComboBoxItem Content="Owner"/><ComboBoxItem Content="Editor"/><ComboBoxItem Content="Reviewer"/><ComboBoxItem Content="Viewer"/></ComboBox><TextBox Grid.Column="2" Header="Expires (local date/time, optional)" Text="{Binding Permissions.Expiration, Mode=TwoWay}"/><Button Grid.Column="3" Content="Assign" Command="{Binding Permissions.AssignCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" VerticalAlignment="Bottom"/></Grid><ListView Grid.Row="1" ItemsSource="{Binding Permissions.Items}" SelectedItem="{Binding Permissions.Selected, Mode=TwoWay}" AutomationProperties.Name="Problem authoring assignments"><ListView.ItemTemplate><DataTemplate><Grid Padding="9" ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding UserId}"/><TextBlock Grid.Column="1" Text="{Binding Role}"/><TextBlock Grid.Column="2" Text="{Binding Status}"/><TextBlock Grid.Column="3" Text="{Binding ExpiresAtUtc}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><Grid Grid.Row="2" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBox Header="Examination identifier" Text="{Binding Permissions.ExamId, Mode=TwoWay}"/><Button Content="Assign examination" Command="{Binding Permissions.AssignExamCommand}" HorizontalAlignment="Left"/></StackPanel><Button Grid.Column="1" Content="Remove selected examination" Command="{Binding Permissions.RemoveExamCommand}" VerticalAlignment="Bottom" Style="{StaticResource MastemisDestructiveButtonStyle}"/><ListView Grid.Column="2" ItemsSource="{Binding Permissions.Exams}" SelectedItem="{Binding Permissions.SelectedExam, Mode=TwoWay}" AutomationProperties.Name="Assigned examinations"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="6"><TextBlock Text="{Binding ExamTitle}"/><TextBlock Text="{Binding ExamState}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></Grid><StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"><Button Content="Refresh" Command="{Binding Permissions.RefreshCommand}"/><Button Content="Revoke selected" Command="{Binding Permissions.RevokeCommand}" Style="{StaticResource MastemisDestructiveButtonStyle}"/><TextBlock Text="{Binding Permissions.Status}" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite"/><TextBlock Text="{Binding Permissions.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" AutomationProperties.LiveSetting="Assertive"/></StackPanel></Grid>
</UserControl>
