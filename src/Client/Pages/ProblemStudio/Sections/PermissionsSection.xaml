<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.PermissionsSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Padding="14" RowSpacing="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="User identifier" Text="{Binding Permissions.UserId, Mode=TwoWay}"/><ComboBox Grid.Column="1" Header="Authoring role" SelectedValue="{Binding Permissions.Role, Mode=TwoWay}"><ComboBoxItem Content="Owner"/><ComboBoxItem Content="Editor"/><ComboBoxItem Content="Reviewer"/><ComboBoxItem Content="Viewer"/></ComboBox><Button Grid.Column="2" Content="Assign" Command="{Binding Permissions.AssignCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" VerticalAlignment="Bottom"/></Grid><ListView Grid.Row="1" ItemsSource="{Binding Permissions.Items}" SelectedItem="{Binding Permissions.Selected, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><Grid Padding="9" ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding UserId}"/><TextBlock Grid.Column="1" Text="{Binding Role}"/><TextBlock Grid.Column="2" Text="{Binding Status}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"><Button Content="Refresh" Command="{Binding Permissions.RefreshCommand}"/><Button Content="Revoke selected" Command="{Binding Permissions.RevokeCommand}"/><TextBlock Text="{Binding Permissions.Status}" VerticalAlignment="Center"/><TextBlock Text="{Binding Permissions.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/></StackPanel></Grid>
</UserControl>
