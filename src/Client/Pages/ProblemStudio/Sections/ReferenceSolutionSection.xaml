<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.ReferenceSolutionSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Padding="14" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <StackPanel Spacing="9"><TextBlock Text="Source files" Style="{StaticResource MastemisSectionTitleStyle}"/><ComboBox Header="Language" SelectedValue="{Binding ReferenceSolution.Language, Mode=TwoWay}"><ComboBoxItem Content="cpp"/><ComboBoxItem Content="csharp"/></ComboBox><ListView ItemsSource="{Binding ReferenceSolution.Sources}" SelectedItem="{Binding ReferenceSolution.Selected, Mode=TwoWay}" DisplayMemberPath="FileName" MinHeight="180" AutomationProperties.Name="Reference solution source files"/><TextBox Header="New logical file" Text="{Binding ReferenceSolution.NewFileName, Mode=TwoWay}"/><Button Content="Add source" Command="{Binding ReferenceSolution.AddFileCommand}"/><Button Content="Remove selected" Command="{Binding ReferenceSolution.RemoveFileCommand}" Style="{StaticResource MastemisDestructiveButtonStyle}"/></StackPanel>
    <Grid Grid.Column="1" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox Header="Logical filename" Text="{Binding ReferenceSolution.Selected.FileName, Mode=TwoWay}"/><TextBox Grid.Row="1" Text="{Binding ReferenceSolution.Selected.Content, Mode=TwoWay}" AcceptsReturn="True" FontFamily="Cascadia Mono,Consolas,monospace" TextWrapping="NoWrap" Background="{ThemeResource MastemisEditorBrush}" AutomationProperties.Name="Reference solution source editor"/><StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"><Button Content="Load revision" Command="{Binding ReferenceSolution.RefreshCommand}"/><Button Content="Save revision" Command="{Binding ReferenceSolution.SaveCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/><TextBlock Text="{Binding ReferenceSolution.Status}" VerticalAlignment="Center"/><TextBlock Text="{Binding ReferenceSolution.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/></StackPanel></Grid>
  </Grid>
</UserControl>
