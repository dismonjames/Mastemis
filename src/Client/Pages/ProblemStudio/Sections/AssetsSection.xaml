<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.AssetsSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Padding="16" RowSpacing="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <TextBlock Text="Problem assets" Style="{StaticResource MastemisSectionTitleStyle}"/>
    <Grid Grid.Row="1" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="Logical name" Text="{Binding Assets.LogicalName, Mode=TwoWay}" PlaceholderText="diagram.png"/><Button Grid.Column="1" Content="Choose file" Command="{Binding Assets.PickCommand}" VerticalAlignment="Bottom"/><Button Grid.Column="2" Content="Upload" Command="{Binding Assets.UploadCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" VerticalAlignment="Bottom"/></Grid>
    <ListView Grid.Row="2" ItemsSource="{Binding Assets.Items}" SelectedItem="{Binding Assets.Selected, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><Grid Padding="8" ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="{Binding LogicalName}"/><TextBlock Grid.Column="1" Text="{Binding ContentType}"/><TextBlock Grid.Column="2" Text="{Binding Length}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"><Button Content="Refresh" Command="{Binding Assets.RefreshCommand}"/><Button Content="Save selected" Command="{Binding Assets.DownloadCommand}"/><Button Content="Delete" Command="{Binding Assets.DeleteCommand}" Style="{StaticResource MastemisDestructiveButtonStyle}"/><TextBlock Text="{Binding Assets.PendingFile}" VerticalAlignment="Center"/><TextBlock Text="{Binding Assets.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" AutomationProperties.LiveSetting="Assertive"/></StackPanel>
  </Grid>
</UserControl>
