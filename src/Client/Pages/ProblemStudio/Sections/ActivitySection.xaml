<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.ActivitySection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Padding="14" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="Event kind" PlaceholderText="Leave blank for all activity" Text="{Binding Activity.Filter, Mode=TwoWay}"/><Button Grid.Column="1" Content="Refresh" Command="{Binding Activity.RefreshCommand}" VerticalAlignment="Bottom"/></Grid><ListView Grid.Row="1" ItemsSource="{Binding Activity.Items}"><ListView.ItemTemplate><DataTemplate><Grid Padding="10" ColumnSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Timestamp}" Style="{StaticResource MastemisCaptionTextStyle}"/><TextBlock Grid.Column="1" Text="{Binding Kind}" FontWeight="SemiBold"/><StackPanel Grid.Column="2"><TextBlock Text="{Binding Summary}" TextWrapping="Wrap"/><TextBlock Text="{Binding Actor}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></Grid></DataTemplate></ListView.ItemTemplate></ListView><StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"><Button Content="Load more" Command="{Binding Activity.MoreCommand}" IsEnabled="{Binding Activity.HasMore}"/><TextBlock Text="{Binding Activity.Status}" VerticalAlignment="Center"/><TextBlock Text="{Binding Activity.Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/></StackPanel></Grid>
</UserControl>
