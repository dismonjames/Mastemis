<UserControl x:Class="Mastemis.Client.Pages.ProblemStudio.Sections.TestsSection" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Padding="14" RowSpacing="10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Orientation="Horizontal" Spacing="8"><ComboBox Width="220" Header="Test-set version" ItemsSource="{Binding Tests.Versions}" SelectedItem="{Binding Tests.SelectedVersion, Mode=TwoWay}" DisplayMemberPath="Version"/><Button Content="Refresh metadata" Command="{Binding Tests.RefreshCommand}"/><Button Content="Load more" Command="{Binding Tests.MoreCommand}" IsEnabled="{Binding Tests.HasMore}"/><Button Content="Preview input" Command="{Binding Tests.PreviewInputCommand}"/><Button Content="Preview output" Command="{Binding Tests.PreviewOutputCommand}"/><TextBlock Text="{Binding Tests.Status}" VerticalAlignment="Center"/></StackPanel><ListView Grid.Row="1" ItemsSource="{Binding Tests.Items}" SelectedItem="{Binding Tests.Selected, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><Grid Padding="8" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="{Binding TestIndex}"/><TextBlock Grid.Column="1" Text="{Binding Group}"/><TextBlock Grid.Column="2" Text="{Binding Visibility}"/><TextBlock Grid.Column="3" Text="{Binding InputLength}"/><TextBlock Grid.Column="4" Text="{Binding OutputLength}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><Border Grid.Row="2" Background="{ThemeResource MastemisEditorBrush}" Padding="12" CornerRadius="6"><ScrollViewer><TextBlock Text="{Binding Tests.Preview}" FontFamily="Cascadia Mono,Consolas,monospace" TextWrapping="NoWrap"/></ScrollViewer></Border></Grid>
</UserControl>
