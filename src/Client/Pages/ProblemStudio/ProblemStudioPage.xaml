<Page x:Class="Mastemis.Client.Pages.ProblemStudio.ProblemStudioPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Problem Studio" Style="{StaticResource MastemisPageTitleStyle}"/><TextBlock Text="Metadata · Statements · Assets · MAS · Reference solution · Generation · Tests · Packages · Permissions" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><Button Content="Refresh drafts" Command="{Binding RefreshCommand}"/><Button Content="Load MAS" Command="{Binding LoadCommand}"/></StackPanel></Grid>
  <Grid Grid.Row="1" Margin="0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/><ColumnDefinition Width="320"/></Grid.ColumnDefinitions>
   <Border Style="{StaticResource MastemisCardStyle}" Margin="0,0,12,0"><StackPanel Spacing="10"><TextBlock Text="Authorized drafts" Style="{StaticResource MastemisSectionTitleStyle}"/><ListView ItemsSource="{Binding Drafts}" SelectedItem="{Binding SelectedDraft, Mode=TwoWay}" AutomationProperties.Name="Authorized problem drafts"><ListView.ItemTemplate><DataTemplate><StackPanel Margin="4"><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Text="{Binding DefaultLocale}" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
   <Border Grid.Column="1" Style="{StaticResource MastemisCardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="MAS source" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Grid.Row="1" Margin="0,10" Text="{Binding Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" FontFamily="Cascadia Mono,Consolas,monospace" TextWrapping="NoWrap" AutomationProperties.Name="MAS source editor"/><StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"><Button Content="Save" Command="{Binding SaveMasCommand}"/><Button Content="Validate" Command="{Binding ValidateCommand}"/><TextBox Width="100" Header="Seed" Text="{Binding Seed, Mode=TwoWay}"/><Button Content="Generate" Command="{Binding GenerateCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel></Grid></Border>
   <Border Grid.Column="2" Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="10"><TextBlock Text="Diagnostics" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="{Binding Status}"/><ListView ItemsSource="{Binding Diagnostics}"><ListView.ItemTemplate><DataTemplate><StackPanel Margin="2,6"><TextBlock Text="{Binding Code}" FontWeight="SemiBold"/><TextBlock Text="{Binding Message}" TextWrapping="Wrap"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
  </Grid><InfoBar Grid.Row="2" IsOpen="{Binding HasError}" Severity="Error" Title="Problem Studio request failed" Message="{Binding Error}" IsClosable="False"/>
 </Grid>
</Page>
