<Page x:Class="Mastemis.Client.Pages.Settings.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><ScrollViewer><StackPanel Margin="28" Spacing="16" MaxWidth="720"><TextBlock Text="Settings" Style="{StaticResource MastemisPageTitleStyle}"/><ComboBox Header="Theme" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme, Mode=TwoWay}"/><TextBox Header="Language" Text="{Binding Language, Mode=TwoWay}"/><NumberBox Header="Editor font size" Value="{Binding EditorFontSize, Mode=TwoWay}" Minimum="10" Maximum="28"/><NumberBox Header="Tab size" Value="{Binding TabSize, Mode=TwoWay}" Minimum="2" Maximum="8"/><NumberBox Header="Autosave interval (seconds)" Value="{Binding AutosaveSeconds, Mode=TwoWay}" Minimum="2" Maximum="60"/><CheckBox Content="Reduce motion" IsChecked="{Binding ReducedMotion, Mode=TwoWay}"/><CheckBox Content="Compact table density" IsChecked="{Binding CompactTables, Mode=TwoWay}"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Load" Command="{Binding LoadCommand}"/><Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel><TextBlock Text="{Binding Status}" Style="{StaticResource MastemisMutedTextStyle}"/><TextBlock Text="Passwords and authentication cookies are never stored in these preferences." Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel></ScrollViewer></Page>
