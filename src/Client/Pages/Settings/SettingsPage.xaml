<Page x:Class="Mastemis.Client.Pages.Settings.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls"><ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="760" HorizontalAlignment="Stretch"><controls:PageHeader Eyebrow="PREFERENCES" Title="Settings" Subtitle="Appearance and editor preferences are stored locally without credentials."/><Border Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="14"><TextBlock Text="Appearance" Style="{StaticResource MastemisSectionTitleStyle}"/><ComboBox Header="Theme" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme, Mode=TwoWay}" Style="{StaticResource MastemisFormComboBoxStyle}" AutomationProperties.HelpText="Applies immediately and is saved when Save is selected."/><TextBox Header="Language" Text="{Binding Language, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><CheckBox Content="Reduce motion" IsChecked="{Binding ReducedMotion, Mode=TwoWay}" AutomationProperties.HelpText="Disables optional visual transitions."/><CheckBox Content="Compact table density" IsChecked="{Binding CompactTables, Mode=TwoWay}"/></StackPanel></Border><Border Style="{StaticResource MastemisCardStyle}"><StackPanel Spacing="14"><TextBlock Text="Editor" Style="{StaticResource MastemisSectionTitleStyle}"/><NumberBox Header="Editor font size" Value="{Binding EditorFontSize, Mode=TwoWay}" Minimum="10" Maximum="28" Style="{StaticResource MastemisFormNumberBoxStyle}"/><NumberBox Header="Tab size" Value="{Binding TabSize, Mode=TwoWay}" Minimum="2" Maximum="8" Style="{StaticResource MastemisFormNumberBoxStyle}"/><NumberBox Header="Autosave interval (seconds)" Value="{Binding AutosaveSeconds, Mode=TwoWay}" Minimum="2" Maximum="60" Style="{StaticResource MastemisFormNumberBoxStyle}"/></StackPanel></Border><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Reload saved values" Command="{Binding LoadCommand}"/><Button Content="Save preferences" Command="{Binding SaveCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel><TextBlock Text="{Binding Status}" Style="{StaticResource MastemisMutedTextStyle}" AutomationProperties.LiveSetting="Polite"/><TextBlock Text="Passwords and authentication cookies are never stored in these preferences." Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel></ScrollViewer></Page>
