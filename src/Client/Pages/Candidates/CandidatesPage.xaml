<Page x:Class="Mastemis.Client.Pages.Candidates.CandidatesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="1320" HorizontalAlignment="Stretch">
        <controls:PageHeader Eyebrow="OPERATIONS" Title="Candidates" Subtitle="Register accounts and inspect authorized examination access, sessions, warnings, and account state."><controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}"/></controls:PageHeader.Commands></controls:PageHeader>
        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Candidate operation failed" Message="{Binding Error}" IsClosable="False"/><ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18"><StackPanel Spacing="12"><TextBlock Text="Register candidate" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Header="Examination ID" Text="{Binding ExamId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Human user ID" Text="{Binding UserId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Registration code" Text="{Binding RegistrationCode, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Register candidate" Command="{Binding RegisterCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Left"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Authorized candidates" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Visibility="{Binding HasCandidates, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No candidates found" Message="Enter an examination ID and refresh the scoped candidate list." Glyph="&#xE716;"/><ListView ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><Grid Padding="12,8" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/><TextBlock Text="{Binding Username}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding AccessState}"/><TextBlock Grid.Column="2" Text="{Binding SessionState}"/><TextBlock Grid.Column="3" Text="{Binding WarningCount}" Foreground="{ThemeResource MastemisWarningBrush}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><StackPanel Orientation="Horizontal" Spacing="8" Margin="14"><Button Content="Enable account" Command="{Binding EnableCommand}"/><Button Content="Disable account" Command="{Binding DisableCommand}"/><TextBlock Text="{Binding OperationResult}" VerticalAlignment="Center"/></StackPanel></StackPanel></Border>
        </Grid>
    </StackPanel></ScrollViewer>
</Page>
