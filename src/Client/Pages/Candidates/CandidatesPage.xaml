<Page x:Class="Mastemis.Client.Pages.Candidates.CandidatesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="1320" HorizontalAlignment="Stretch">
        <controls:PageHeader Eyebrow="OPERATIONS" Title="Candidates" Subtitle="Register human accounts for an examination without exposing credentials or source content."/>
        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Candidate operation failed" Message="{Binding Error}" IsClosable="False"/><ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18"><StackPanel Spacing="12"><TextBlock Text="Register candidate" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Header="Examination ID" Text="{Binding ExamId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Human user ID" Text="{Binding UserId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Registration code" Text="{Binding RegistrationCode, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Register candidate" Command="{Binding RegisterCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Left"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Registrations created in this session" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Visibility="{Binding HasRegistrations, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No candidate records loaded" Message="The backend currently supports scoped registration but does not expose a candidate-list query." Glyph="&#xE716;"/><ListView ItemsSource="{Binding Registrations}"><ListView.ItemTemplate><DataTemplate><Grid Padding="12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding RegistrationCode}" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding UserId}" Style="{StaticResource MastemisCodeTextStyle}"/><TextBlock Grid.Column="2" Text="{Binding Id}" Style="{StaticResource MastemisCodeTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
        </Grid>
    </StackPanel></ScrollViewer>
</Page>
