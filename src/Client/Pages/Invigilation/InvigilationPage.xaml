<Page x:Class="Mastemis.Client.Pages.Invigilation.InvigilationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:Mastemis.Client.Controls">
    <Grid Padding="{StaticResource MastemisPageMargin}" RowSpacing="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <controls:PageHeader Eyebrow="LIVE OPERATIONS" Title="Invigilation" Subtitle="Join an authorized examination scope and monitor policy-safe realtime events."/>
        <Grid Grid.Row="1" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox Header="Examination ID" Text="{Binding ExaminationId, Mode=TwoWay}" PlaceholderText="00000000-0000-0000-0000-000000000000"/>
            <ComboBox Grid.Column="1" Header="Event filter" ItemsSource="{Binding Filters}" SelectedItem="{Binding Filter, Mode=TwoWay}"/>
            <Button Grid.Column="2" VerticalAlignment="Bottom" Content="Join live scope" Command="{Binding SubscribeCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/>
        </Grid>
        <Border Grid.Row="2" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Padding="16,12" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Realtime event stream" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Grid.Column="1" Text="{Binding State}" Foreground="{ThemeResource MastemisAccentBrush}"/></Grid>
                <Grid Grid.Row="1" ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions><Grid RowSpacing="8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid ColumnSpacing="8" Padding="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="105"/><ColumnDefinition Width="105"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox PlaceholderText="Search candidates" Text="{Binding Search, Mode=TwoWay}" AutomationProperties.Name="Search candidates"/><ComboBox Grid.Column="1" SelectedValue="{Binding ConnectionFilter, Mode=TwoWay}" AutomationProperties.Name="Connection filter"><ComboBoxItem Content="All"/><ComboBoxItem Content="Connected"/><ComboBoxItem Content="Disconnected"/></ComboBox><ComboBox Grid.Column="2" SelectedValue="{Binding WarningFilter, Mode=TwoWay}" AutomationProperties.Name="Warning filter"><ComboBoxItem Content="All"/><ComboBoxItem Content="With warnings"/><ComboBoxItem Content="No warnings"/></ComboBox><Button Grid.Column="3" Content="Clear" Command="{Binding ClearFiltersCommand}" AutomationProperties.HelpText="Clear all candidate filters."/></Grid><ListView Grid.Row="1" ItemsSource="{Binding VisibleCandidates}" SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}" AutomationProperties.Name="Live candidates"><ListView.Header><Grid Padding="12,9" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Candidate" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="Connection" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="Warnings" FontWeight="SemiBold"/></Grid></ListView.Header><ListView.ItemTemplate><DataTemplate><Grid Padding="12,8" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding DisplayName}"/><TextBlock Grid.Column="1" Text="{Binding ConnectionState}"/><TextBlock Grid.Column="2" Text="{Binding WarningCount}" Foreground="{ThemeResource MastemisWarningBrush}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></Grid><ScrollViewer Grid.Column="1" AutomationProperties.Name="Selected candidate details"><StackPanel Padding="12" Spacing="10"><TextBlock Text="Candidate detail" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="{Binding SelectedCandidate.DisplayName}" FontSize="20"/><TextBlock Text="{Binding SelectedCandidate.SessionState}"/><TextBlock Text="Warnings" FontWeight="SemiBold"/><ListView ItemsSource="{Binding CandidateWarnings}" MaxHeight="180" AutomationProperties.Name="Confirmed warning timeline"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="6"><TextBlock Text="{Binding Severity}"/><TextBlock Text="{Binding IssuedAtUtc}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView><TextBlock Text="Recent SFE events" FontWeight="SemiBold"/><ListView ItemsSource="{Binding CandidateEvents}" MaxHeight="220" AutomationProperties.Name="Recent secure focus events"><ListView.ItemTemplate><DataTemplate><StackPanel Padding="6"><TextBlock Text="{Binding EventType}"/><TextBlock Text="{Binding EvaluationState}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></ScrollViewer></Grid>
            </Grid>
        </Border>
        <InfoBar Grid.Row="2" VerticalAlignment="Top" IsOpen="{Binding HasError}" Severity="Error" Title="Live scope unavailable" Message="{Binding Error}" IsClosable="False"/>
    </Grid>
</Page>
