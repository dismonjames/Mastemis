<Page x:Class="Mastemis.Client.Pages.CandidateExam.CandidateExamPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Loaded="Page_Loaded" Unloaded="Page_Unloaded">
    <Grid Background="{ThemeResource MastemisCanvasBrush}">
        <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Padding="20,12" Background="{ThemeResource MastemisNavigationBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Spacing="3"><TextBlock Text="Candidate examination" FontSize="21" FontWeight="SemiBold"/><StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding SessionState}" Style="{StaticResource MastemisCaptionTextStyle}"/><TextBlock Text="{Binding WarningSummary}" Foreground="{ThemeResource MastemisWarningBrush}" FontSize="12"/><TextBlock Text="{Binding SaveState}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><TextBox Width="250" PlaceholderText="Session ID" Text="{Binding SessionId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Load session" Command="{Binding LoadCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}"/></StackPanel></Grid>

        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="228"/><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisNavigationBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,1,0" Padding="14"><StackPanel Spacing="13"><TextBlock Text="Problems" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="The server does not yet expose a candidate problem-list query. Enter the assigned problem identifier." Style="{StaticResource MastemisCaptionTextStyle}"/><TextBox Header="Problem ID" Text="{Binding ProblemId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><ComboBox Header="Language" ItemsSource="{Binding Languages}" SelectedItem="{Binding Language, Mode=TwoWay}"/><Border Padding="10" Background="{ThemeResource MastemisSubtleBrush}" CornerRadius="6"><StackPanel Spacing="3"><TextBlock Text="Session" FontWeight="SemiBold"/><TextBlock Text="{Binding SessionState}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel></Border></StackPanel></Border>

            <TabView Grid.Column="1" Margin="10,8" IsAddTabButtonVisible="False"><TabViewItem Header="Statement" IsClosable="False"><Grid><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480" Spacing="8"><FontIcon Glyph="&#xE82D;" FontSize="28" Foreground="{ThemeResource MastemisMutedTextBrush}"/><TextBlock Text="Statement unavailable" FontSize="17" FontWeight="SemiBold" TextAlignment="Center"/><TextBlock Text="The current backend does not expose the candidate problem statement through a scoped endpoint." Style="{StaticResource MastemisMutedTextStyle}" TextAlignment="Center"/></StackPanel></Grid></TabViewItem><TabViewItem Header="Code" IsClosable="False"><Grid><TextBox Text="{Binding Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="{Binding IsLocked}" Style="{StaticResource MastemisEditorTextBoxStyle}" AutomationProperties.Name="Source code editor"/><Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Padding="8,4" Background="{ThemeResource MastemisSubtleBrush}" CornerRadius="4"><TextBlock Text="{Binding SaveState}" Style="{StaticResource MastemisCaptionTextStyle}"/></Border></Grid></TabViewItem></TabView>

            <Border Grid.Column="2" Background="{ThemeResource MastemisNavigationBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1,0,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid Padding="14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Submissions" Style="{StaticResource MastemisSectionTitleStyle}"/><Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshSubmissionsCommand}"/></Grid><ListView Grid.Row="1" ItemsSource="{Binding Submissions}"><ListView.ItemTemplate><DataTemplate><Grid Padding="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding State}" FontWeight="SemiBold"/><TextBlock Text="{Binding Language}" Style="{StaticResource MastemisCaptionTextStyle}"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Id}" MaxWidth="72" TextTrimming="CharacterEllipsis" Style="{StaticResource MastemisCaptionTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><StackPanel Grid.Row="2" Padding="14" Spacing="8" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,1,0,0"><Button Content="Save now" Command="{Binding SaveCommand}" HorizontalAlignment="Stretch"/><Button Content="Submit solution" Command="{Binding SubmitCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Stretch" IsEnabled="{Binding IsLocked, Converter={StaticResource InverseBooleanConverter}}"/></StackPanel></Grid></Border>
        </Grid>
        <InfoBar Grid.Row="2" IsOpen="{Binding HasError}" Severity="Error" Title="Candidate operation failed" Message="{Binding Error}" IsClosable="False" Margin="12"/>
        <Border Grid.RowSpan="3" Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#AA080D18"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"><FontIcon Glyph="&#xE72E;" FontSize="32" Foreground="{ThemeResource MastemisWarningBrush}"/><TextBlock Text="This examination session is locked" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="Draft saves and submissions are disabled after completion or termination." Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel></Border>
    </Grid>
</Page>
