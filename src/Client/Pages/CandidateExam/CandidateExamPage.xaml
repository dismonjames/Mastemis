<Page x:Class="Mastemis.Client.Pages.CandidateExam.CandidateExamPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Border Style="{StaticResource MastemisCardStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Candidate workspace" Style="{StaticResource MastemisPageTitleStyle}"/><TextBlock Text="{Binding SessionState}" Style="{StaticResource MastemisMutedTextStyle}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><TextBox Width="300" Header="Session ID" Text="{Binding SessionId, Mode=TwoWay}"/><Button Content="Load" Command="{Binding LoadCommand}" VerticalAlignment="Bottom"/></StackPanel></Grid></Border>
  <Grid Grid.Row="1" Margin="0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource MastemisCardStyle}" Margin="0,0,12,0"><StackPanel Spacing="12"><TextBlock Text="Submission" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBox Header="Problem ID" Text="{Binding ProblemId, Mode=TwoWay}"/><ComboBox Header="Language" ItemsSource="{Binding Languages}" SelectedItem="{Binding Language, Mode=TwoWay}"/><TextBlock Text="{Binding SaveState}" Style="{StaticResource MastemisMutedTextStyle}"/><Button Content="Save draft" Command="{Binding SaveCommand}"/><Button Content="Submit" Command="{Binding SubmitCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}"/></StackPanel></Border><TextBox Grid.Column="1" Text="{Binding Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" FontFamily="Cascadia Mono,Consolas,monospace" FontSize="14" TextWrapping="NoWrap" IsReadOnly="{Binding IsLocked}" AutomationProperties.Name="Source code editor"/></Grid>
  <InfoBar Grid.Row="2" IsOpen="{Binding HasError}" Severity="Error" Title="Candidate operation failed" Message="{Binding Error}" IsClosable="False"/>
 </Grid>
</Page>
