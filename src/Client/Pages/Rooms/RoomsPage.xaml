<Page x:Class="Mastemis.Client.Pages.Rooms.RoomsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="1320" HorizontalAlignment="Stretch">
        <controls:PageHeader Eyebrow="OPERATIONS" Title="Rooms" Subtitle="Create rooms and inspect scoped capacity, connectivity, and warnings."><controls:PageHeader.Commands><Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource MastemisSecondaryButtonStyle}"/></controls:PageHeader.Commands></controls:PageHeader>
        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Room operation failed" Message="{Binding Error}" IsClosable="False"/><ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18"><StackPanel Spacing="12"><TextBlock Text="Create room" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="Room codes and invigilator assignments remain server-authoritative." Style="{StaticResource MastemisCaptionTextStyle}"/><TextBox Header="Examination ID" Text="{Binding ExamId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Room name" Text="{Binding Name, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Create room" Command="{Binding CreateCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Left"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Authorized rooms" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Visibility="{Binding HasLoadedRooms, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No rooms found" Message="Enter an examination ID and refresh the scoped room list." Glyph="&#xE8B7;"/><ListView ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom, Mode=TwoWay}" AutomationProperties.Name="Authorized rooms"><ListView.ItemTemplate><DataTemplate><Grid Padding="12,8" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Code}" Style="{StaticResource MastemisCodeTextStyle}"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding CandidateCount}"/><TextBlock Grid.Column="2" Text="{Binding ConnectedCount}"/><TextBlock Grid.Column="3" Text="{Binding WarningCount}" Foreground="{ThemeResource MastemisWarningBrush}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView><Grid Padding="14" ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Header="Invigilator user ID" Text="{Binding InvigilatorUserId, Mode=TwoWay}"/><Button Grid.Column="1" Content="Assign" Command="{Binding AssignInvigilatorCommand}" VerticalAlignment="Bottom"/><Button Grid.Column="2" Content="Refresh assignments" Command="{Binding LoadInvigilatorsCommand}" VerticalAlignment="Bottom"/></Grid><ListView ItemsSource="{Binding Invigilators}" SelectedItem="{Binding SelectedInvigilator, Mode=TwoWay}" DisplayMemberPath="UserId" MaxHeight="140" AutomationProperties.Name="Assigned room invigilators"/><Button Content="Remove selected invigilator" Command="{Binding RemoveInvigilatorCommand}" Margin="14,4,14,14" HorizontalAlignment="Left" Style="{StaticResource MastemisDestructiveButtonStyle}"/></StackPanel></Border>
        </Grid>
    </StackPanel></ScrollViewer>
</Page>
