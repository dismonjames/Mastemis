<Page x:Class="Mastemis.Client.Pages.Rooms.RoomsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:Mastemis.Client.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="{StaticResource MastemisPageMargin}" Spacing="18" MaxWidth="1320" HorizontalAlignment="Stretch">
        <controls:PageHeader Eyebrow="OPERATIONS" Title="Rooms" Subtitle="Create rooms in an authorized examination and manage their operational context."/>
        <InfoBar IsOpen="{Binding HasError}" Severity="Error" Title="Room operation failed" Message="{Binding Error}" IsClosable="False"/><ProgressBar IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <Border Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18"><StackPanel Spacing="12"><TextBlock Text="Create room" Style="{StaticResource MastemisSectionTitleStyle}"/><TextBlock Text="Room codes and invigilator assignments remain server-authoritative." Style="{StaticResource MastemisCaptionTextStyle}"/><TextBox Header="Examination ID" Text="{Binding ExamId, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><TextBox Header="Room name" Text="{Binding Name, Mode=TwoWay}" Style="{StaticResource MastemisFormTextBoxStyle}"/><Button Content="Create room" Command="{Binding CreateCommand}" Style="{StaticResource MastemisPrimaryButtonStyle}" HorizontalAlignment="Left"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{ThemeResource MastemisSurfaceBrush}" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="1" CornerRadius="8"><StackPanel><Grid Padding="18,14" BorderBrush="{ThemeResource MastemisBorderBrush}" BorderThickness="0,0,0,1"><TextBlock Text="Rooms created in this session" Style="{StaticResource MastemisSectionTitleStyle}"/></Grid><controls:EmptyState Visibility="{Binding HasRooms, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Title="No rooms loaded" Message="The server does not currently expose a room-list query. Newly created authoritative rooms appear here." Glyph="&#xE8B7;"/><ListView ItemsSource="{Binding CreatedRooms}"><ListView.ItemTemplate><DataTemplate><Grid Padding="12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Id}" Style="{StaticResource MastemisCodeTextStyle}"/></Grid></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
        </Grid>
    </StackPanel></ScrollViewer>
</Page>
